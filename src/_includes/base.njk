<!DOCTYPE html>
<html lang="en">
<head>
  {% set canonicalUrl = site.url + page.url %}
  {% set pageTitle = title + " - " + site.name %}
  {% set isBlogPost = page.url != "/blog/" and page.url.slice(0, 6) == "/blog/" %}
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ pageTitle | safe }}</title>
  {% if description %}
  <meta name="description" content="{{ description | striptags | escape }}" />
  {% endif %}
  <link rel="canonical" href="{{ canonicalUrl }}" />
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/styles.css" />
  <meta property="og:title" content="{{ pageTitle | safe }}" />
  {% if description %}
  <meta property="og:description" content="{{ description | striptags | escape }}" />
  <meta name="twitter:description" content="{{ description | striptags | escape }}" />
  {% endif %}
  <meta property="og:url" content="{{ canonicalUrl }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:type" content="{% if isBlogPost %}article{% else %}website{% endif %}" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ pageTitle | safe }}" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  {% if site.analyticsMeasurementId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analyticsMeasurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analyticsMeasurementId }}');
  </script>
  {% endif %}
  <script src="/main.js"></script>
</head>
<body class="main-body">

  <div class="box nav-box">
    <nav class="nav-bar">
      <div class="nav-title">Re Alvarez Parmar's personal site</div>
      <div class="nav-links">
        {% for page in collections.pages %}
          <a href="{{ page.url }}" class="nav-link">{{ page.data.title }}</a>
        {% endfor %}
      </div>
      <span class="dark-toggle">
        <span class="material-symbols-outlined">light_mode</span>
        <label class="switch">
          <input
            type="checkbox"
            id="darkmode"
            onclick="change_mode()"
            aria-labelledby="darkmodelabel"
          />
          <span class="slider round"></span>
        </label>
        <span class="material-symbols-outlined">dark_mode</span>
      </span>
    </nav>
  </div>

  <div class="content-wrapper">
    <div class="box">{{ content | safe }}</div>

    <div class="box footer footer-box">
      
      <p class="footer-text">© {{ currentYear }} Re Alvarez Parmar</p>
    </div>
  </div>
</body>
</html>
